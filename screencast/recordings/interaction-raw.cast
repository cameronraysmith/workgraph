u001b[39m                                          \u001b[38;5;6m\u2502\r\n\u2502\u001b[39m                                                               \u001b[38;5;6m\u2502\r\n\u2502\u001b[39m  \u2022 \u001b[38;5;222m\u001b[48;5;236m build-snark-filter \u001b[39m\u001b[49m \u2192 after \u001b[38;5;222m\u001b[48;5;236m count-syllables \u001b[39m\u001b[49m (tone       \u001b[38;5;6m\u2502\r\n\u2502\u001b[39m  adjuster: neutral \u2192 snarky)                                  \u001b[38;5;6m\u2502\r\n\u2502\u001b[39m  \u2022 \u001b[38;5;222m\u001b[48;5;236m draft-roast-haikus \u001b[39m\u001b[49m \u2192 after \u001b[38;5;222m\u001b[48;5;236m build-snark-filter \u001b[39m\u001b[49m +        \u001b[38;5;6m\u2502\r\n\u2502\u001b[39m  \u001b[38;5;222m\u001b[48;5;236mwire-haiku-engine\u001b[39m\u001b[49m                                            \u001b[38;5;6m\u2502\r\n\u2502\u001b[39m  \u2022 \u001b[38;5;222m\u001b[48;5;236m review-roasts \u001b[39m\u001b[49m \u2192 after \u001b[38;5;222m\u001b[48;5;236m draft-roast-haikus \u001b[39m\u001b[49m \u001b[3m(pending next\u001b[0m \u001b[38;5;6m\u2502\r\n\u2502\u001b[39m  \u001b[3mcycle)\u001b[0m                                                       \u001b[38;5;6m\u2502\r\n\u2502\u001b[39m                                                               \u001b[38;5;6m\u2502\r\n\u2502\u001b[39m  The first two will unblock as soon as \u001b[38;5;222m\u001b[48;5;236m count-syllables \u001b[39m\u001b[49m and  \u001b[38;5;6m\u2502\r\n\u2502\u001b[39m  \u001b[38;5;222m\u001b[48;5;236mwire-haiku-engine \u001b[39m\u001b[49m complete. \u001b[38;5;222m\u001b[48;5;236m review-roasts \u001b[39m\u001b[49m will slot in    \u001b[38;5;6m\u2502\r\n\u2502\u001b[39m  right after. Roast pipeline will run fully parallel to the   \u001b[38;5;6m\u2502\r\n\u2502\u001b[39m  normal \u001b[38;5;222m\u001b[48;5;236m draft-haikus \u001b[39m\u001b[49m \u2192 \u001b[38;5;222m\u001b[48;5;236m review-quality \u001b[39m\u001b[49m flow.               \u001b[38;5;6m\u2502\r\n\u2502\u001b[39m                                                               \u001b[38;5;6m\u2502\r\n\u2502\u001b[38;5;8m \u2191\u2193: scroll\u001b[39m                                                    \u001b[38;5;6m\u2502\r\n\u2514\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2518\r\n\u001b[1m\u001b[38;5;15m\u001b[48;2;30;30;30m Graph\u001b[0m\u001b[38;2;80;80;80m\u001b[48;2;30;30;30m | \u001b[1m\u001b[38;2;120;120;120mNAV\u001b[0m\u001b[38;2;80;80;80m\u001b[48;2;30;30;30m | \u001b[38;5;3m\u2191\u2193\u001b[38;2;140;140;140m:select  \u001b[38;5;3mEnter\u001b[38;2;140;140;140m:inspect  \u001b[38;5;3mTab\u001b[38;2;140;140;140m:panel  \u001b[38;5;3m/\u001b[38;2;140;140;140m:search  \u001b[38;2;80;80;80m\u2026\u001b[39m"]
