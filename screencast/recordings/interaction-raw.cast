u001b[49m \u2192 after \u001b[38;5;222m\u001b[48;5;236m scrape-headlines \u001b[39m\u001b[49m +           \u001b[38;5;6m\u2502\r\n\u2502\u001b[39m  \u001b[38;5;222m\u001b[48;5;236mcount-syllables\u001b[39m\u001b[49m                                              \u001b[38;5;6m\u2502\r\n\u2502\u001b[39m  \u2022 \u001b[38;5;222m\u001b[48;5;236m draft-haikus \u001b[39m\u001b[49m \u2192 after \u001b[38;5;222m\u001b[48;5;236m wire-haiku-engine \u001b[39m\u001b[49m + \u001b[38;5;222m\u001b[48;5;236m analyze-mood\u001b[39m\u001b[49m \u001b[38;5;6m\u2502\r\n\u2502\u001b[1m\u001b[38;5;5m\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u001b[0m\u001b[38;5;6m\u2502\r\n\u2502\u001b[1m\u001b[38;5;13m> \u001b[0m\u001b[38;5;0m\u001b[48;5;15m \u001b[39m\u001b[49m                                                            \u001b[38;5;6m\u2502\r\n\u2514\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2518\r\n\u001b[1m\u001b[38;5;15m\u001b[48;2;30;30;30m 0:Chat\u001b[0m\u001b[38;2;80;80;80m\u001b[48;2;30;30;30m | \u001b[1m\u001b[38;5;5mEDIT\u001b[0m\u001b[38;2;80;80;80m\u001b[48;2;30;30;30m | \u001b[38;5;3mEnter\u001b[38;2;140;140;140m:send  \u001b[38;5;3mEsc\u001b[38;2;140;140;140m:cancel  \u001b[38;5;3m\u2191\u2193\u001b[38;2;140;140;140m:history\u001b[38;2;80;80;80m  \u2502 \u001b[1m\u001b[38;5;2mNew task:"]
