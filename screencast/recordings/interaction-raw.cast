001b[39m\u001b[49m \u2192 after \u001b[38;5;222m\u001b[48;5;236m scrape-headlines \u001b[39m\u001b[49m                 \u001b[38;5;8m\u2551\u001b[38;5;6m\u2502\r\n\u2502\u001b[39m  \u2022 \u001b[38;5;222m\u001b[48;5;236m wire-haiku-engine \u001b[39m\u001b[49m \u2192 after \u001b[38;5;222m\u001b[48;5;236m scrape-headlines \u001b[39m\u001b[49m +          \u001b[38;5;8m\u2551\u001b[38;5;6m\u2502\r\n\u2502\u001b[39m  \u001b[38;5;222m\u001b[48;5;236mcount-syllables\u001b[39m\u001b[49m                                             \u001b[38;5;15m\u2588\u001b[38;5;6m\u2502\r\n\u2502\u001b[39m  \u2022 \u001b[38;5;222m\u001b[48;5;236m draft-haikus \u001b[39m\u001b[49m \u2192 after \u001b[38;5;222m\u001b[48;5;236m wire-haiku-engine \u001b[39m\u001b[49m + \u001b[38;5;222m\u001b[48;5;236m analyze-mood\u001b[38;5;15m\u001b[49m\u2588\u001b[38;5;6m\u2502\r\n\u2502\u001b[39m  \u2022 \u001b[38;5;222m\u001b[48;5;236m review-quality \u001b[39m\u001b[49m \u2192 after \u001b[38;5;222m\u001b[48;5;236m draft-haikus \u001b[39m\u001b[49m                   \u001b[38;5;15m\u2588\u001b[38;5;6m\u2502\r\n\u2502\u001b[39m  \u2022 \u001b[38;5;222m\u001b[48;5;236m publish-api \u001b[39m\u001b[49m \u2192 after \u001b[38;5;222m\u001b[48;5;236m review-quality \u001b[39m\u001b[49m + \u001b[38;5;222m\u001b[48;5;236m build-pun-db \u001b[39m\u001b[49m   \u001b[38;5;15m\u2588\u001b[38;5;6m\u2502\r\n\u2502\u001b[39m                                                              \u25bc\u001b[38;5;6m\u2502\r\n\u2502\u001b[38;5;8m \u2191\u2193: scroll\u001b[39m                                                    \u001b[38;5;6m\u2502\r\n\u2514\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u2500\u